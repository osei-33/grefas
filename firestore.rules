rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: services
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - iconName: string (required)
    //   - color: string (required)
    //   - order: number (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: gallery
    // Document ID: auto-generated
    // Fields:
    //   - type: string (required, 'image' | 'video')
    //   - url: string (required)
    //   - thumbnail: string (optional)
    //   - title: string (required)
    //   - category: string (required, 'events' | 'entertainment' | 'consulting')
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Document ID: auth.uid
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin' | 'editor')
    //
    // Collection: bookings
    // Document ID: date string (YYYY-MM-DD)
    // Fields:
    //   - userName: string (required)
    //   - userEmail: string (required)
    //   - userPhone: string (optional)
    //   - serviceId: string (optional)
    //   - serviceTitle: string (optional)
    //   - date: string (required, YYYY-MM-DD)
    //   - notes: string (optional)
    //   - status: string (required, 'pending' | 'confirmed' | 'cancelled')
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isHardcodedAdmin() {
      return isAuthenticated() && 
             request.auth.token != null && 
             'email' in request.auth.token && 
             (request.auth.token.email == "serwaahlinda1995@gmail.com" || 
              request.auth.token.email == "asantegrice@gmail.com" || 
              request.auth.token.email == "asantegrifice@gmail.com" || 
              request.auth.token.email == "oseikwameemmanuel33@gmail.com");
    }

    function isAdmin() {
      return isHardcodedAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isEditor() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor';
    }

    function isStaff() {
      return isHardcodedAdmin() || isAdmin() || isEditor();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidService(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000 &&
             data.iconName is string && data.color is string &&
             (!('category' in data) || (data.category is string && data.category.size() > 0 && data.category.size() < 100)) &&
             (!('price' in data) || data.price is number);
    }

    function isValidGalleryItem(data) {
      return data.type in ['image', 'video'] &&
             data.url is string && data.url.size() > 0 &&
             data.title is string && data.title.size() > 0 &&
             data.category in ['events', 'entertainment', 'consulting'];
    }

    function isValidUser(data) {
      return data.email is string && data.role in ['admin', 'editor', 'guest'];
    }

    function isValidBooking(data) {
      return data.userName is string && data.userName.size() > 0 && data.userName.size() < 100 &&
             data.userEmail is string && data.userEmail.size() > 0 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.time is string && data.time.size() > 0 &&
             data.status in ['pending', 'confirmed', 'cancelled'];
    }

    function isValidBlogPost(data) {
      return data.title is string && data.title.size() > 0 &&
             data.summary is string && data.summary.size() > 0 &&
             data.content is list &&
             data.category is string &&
             data.date is string &&
             data.image is string &&
             data.author is string;
    }

    function isValidNewsletterSubscriber(data) {
      return data.email is string && data.email.size() > 0 && data.email.size() < 250;
    }

    function isValidTeamMember(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role is string && data.role.size() > 0 && data.role.size() < 100 &&
             data.experience is string && data.experience.size() > 0 &&
             data.bio is string && data.bio.size() > 0 &&
             (!data.keys().hasAny(['email']) || (data.email is string && data.email.size() < 120));
    }

    function isValidTestimonial(data) {
      return data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 2000 &&
             (!('authorRole' in data) || (data.authorRole is string && data.authorRole.size() < 100)) &&
             (!('rating' in data) || (data.rating is number && data.rating >= 1 && data.rating <= 5)) &&
             (!('approved' in data) || data.approved is bool) &&
             (!('createdAt' in data) || data.createdAt == request.time);
    }

    function isValidVisitorNotification(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 5000 &&
             data.isActive is bool &&
             (!('type' in data) || data.type is string) &&
             (!('buttonText' in data) || data.buttonText is string) &&
             (!('buttonUrl' in data) || data.buttonUrl is string);
    }

    function isValidReview(data) {
      return data.serviceId is string && data.serviceId.size() > 0 &&
             data.userId is string && data.userId.size() > 0 &&
             data.userName is string && data.userName.size() > 0 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() > 0 && data.comment.size() <= 2000;
    }

    function isValidActivityLog(data) {
      return data.type is string && data.type.size() > 0 && data.type.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 2000 &&
             data.createdAt is string;
    }

    function isValidBookingPass(data) {
      return data.bookingId is string && data.bookingId.size() > 0 && data.bookingId.size() <= 100 &&
             data.orderNumber is string && data.orderNumber.size() > 0 && data.orderNumber.size() <= 100 &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() <= 200 &&
             data.userEmail is string && data.userEmail.size() > 0 && data.userEmail.size() <= 200 &&
             (!('serviceTitle' in data) || (data.serviceTitle is string && data.serviceTitle.size() <= 300)) &&
             (!('generatedByEmail' in data) || (data.generatedByEmail is string && data.generatedByEmail.size() <= 200)) &&
             (!('generatedByName' in data) || (data.generatedByName is string && data.generatedByName.size() <= 200)) &&
             data.timestamp is string && data.timestamp.size() > 0 && data.timestamp.size() <= 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow list: if isAuthenticated() && (isStaff() || ('email' in request.auth.token && resource.data.email == request.auth.token.email));
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update: if isStaff() && isValidService(request.resource.data);
      allow delete: if isStaff();
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow create, update: if isStaff() && isValidBlogPost(request.resource.data);
      allow delete: if isStaff();
    }

    match /newsletter/{subscriberId} {
      allow read, update, delete: if isStaff();
      allow create: if isValidNewsletterSubscriber(request.resource.data);
    }

    match /newsletter_campaigns/{campaignId} {
      allow read, write: if isStaff();
    }

    match /gallery/{itemId} {
      allow read: if true;
      allow create: if isStaff() && isValidGalleryItem(request.resource.data);
      allow update: if true;
      allow delete: if isStaff();
    }

    match /portfolio/{itemId} {
      allow read: if true;
      allow create: if isStaff();
      allow update: if true;
      allow delete: if isStaff();
    }

    match /chat/{messageId} {
      // Allow read if staff OR if it belongs to the user
      // Note: For guests, we rely on the chatId being a non-guessable random string
      allow read: if isStaff() || 
                    (isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.chatId == request.auth.uid)) ||
                    (resource.data.chatId != null);
      
      allow create: if (isAuthenticated() || request.resource.data.chatId != null) && 
                      request.resource.data.text is string && 
                      request.resource.data.text.size() > 0 && 
                      request.resource.data.text.size() < 1000;
      allow update: if isStaff(); // Admins might bridge or moderate
    }

    match /chat_status/{chatId} {
      // Allow read/write for staff or anyone with the chatId
      allow read: if true;
      allow write: if true; 
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidReview(request.resource.data) && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /bookings/{bookingId} {
      allow get, list: if true;
      allow create: if isValidBooking(request.resource.data);
      allow update, delete: if isStaff();
    }

    match /booking_passes/{passId} {
      allow read: if isStaff();
      allow create: if isStaff() && isValidBookingPass(request.resource.data);
      allow update: if isStaff() && isValidBookingPass(request.resource.data);
      allow delete: if isStaff();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || (isStaff() && resource.data.userId == 'admin'));
      allow create: if isAuthenticated() || isStaff() || request.resource.data.userId == 'admin'; 
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])) ||
        (isStaff() && resource.data.userId == 'admin' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']))
      );
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || (isStaff() && resource.data.userId == 'admin'));
    }
    
    match /tasks/{taskId} {
      allow read, write: if isStaff();
    }
    
    match /team_members/{memberId} {
      allow read: if true;
      allow create, update: if isStaff() && isValidTeamMember(request.resource.data);
      allow delete: if isStaff();
    }

    match /messages/{messageId} {
      allow read: if isStaff();
      allow create: if request.resource.data.senderName is string && request.resource.data.senderName.size() > 0 &&
                    request.resource.data.senderEmail is string && request.resource.data.senderEmail.size() > 0 &&
                    request.resource.data.message is string && request.resource.data.message.size() > 0;
      allow update, delete: if isStaff();
    }

    match /service_intakes/{intakeId} {
      allow read: if isStaff() || (isAuthenticated() && (resource.data.userId == request.auth.uid || ('email' in request.auth.token && resource.data.emailAddress == request.auth.token.email)));
      allow create: if request.resource.data.fullName is string && request.resource.data.fullName.size() > 0 &&
                    request.resource.data.dateOfBirth is string && request.resource.data.dateOfBirth.size() > 0 &&
                    request.resource.data.age is number &&
                    request.resource.data.contact is string && request.resource.data.contact.size() > 0 &&
                    request.resource.data.address is string && request.resource.data.address.size() > 0 &&
                    request.resource.data.whatsappNumber is string && request.resource.data.whatsappNumber.size() > 0 &&
                    request.resource.data.emailAddress is string && request.resource.data.emailAddress.size() > 0;
      allow update: if isStaff() || (isAuthenticated() && (resource.data.userId == request.auth.uid || ('email' in request.auth.token && resource.data.emailAddress == request.auth.token.email)) &&
                    (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['fullName', 'userId', 'userEmail', 'emailAddress', 'status', 'price'])));
      allow delete: if isStaff();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if isValidTestimonial(request.resource.data);
      allow update, delete: if isStaff();
    }

    match /visitor_notifications/{notificationId} {
      allow read: if true;
      allow create: if isStaff() && isValidVisitorNotification(request.resource.data);
      allow update: if isStaff() && isValidVisitorNotification(request.resource.data);
      allow delete: if isStaff();
    }

    match /sms_templates/{templateId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /letters/{letterId} {
      allow read, write: if isStaff();
    }

    match /employees/{employeeId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.email == request.auth.token.email);
      allow create, update, delete: if isStaff();
    }

    match /salaries/{salaryId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.employeeEmail == request.auth.token.email);
      allow create, update, delete: if isStaff();
    }
    
    match /transactions/{transactionId} {
      allow read, write: if isStaff();
    }
    
    match /activity_logs/{logId} {
      allow read: if isStaff();
      allow create: if isValidActivityLog(request.resource.data);
    }
    
    match /test/connection {
      allow read: if true;
    }

    match /site_visits/{dateStr} {
      allow read: if true;
      allow create, update: if true;
    }
  }
}
