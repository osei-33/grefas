rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: services
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - iconName: string (required)
    //   - color: string (required)
    //   - order: number (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: gallery
    // Document ID: auto-generated
    // Fields:
    //   - type: string (required, 'image' | 'video')
    //   - url: string (required)
    //   - thumbnail: string (optional)
    //   - title: string (required)
    //   - category: string (required, 'events' | 'entertainment' | 'consulting')
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Document ID: auth.uid
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin' | 'editor')
    //
    // Collection: bookings
    // Document ID: date string (YYYY-MM-DD)
    // Fields:
    //   - userName: string (required)
    //   - userEmail: string (required)
    //   - userPhone: string (optional)
    //   - serviceId: string (optional)
    //   - serviceTitle: string (optional)
    //   - date: string (required, YYYY-MM-DD)
    //   - notes: string (optional)
    //   - status: string (required, 'pending' | 'confirmed' | 'cancelled')
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "serwaahlinda1995@gmail.com" || request.auth.token.email == "asantegrice@gmail.com" || request.auth.token.email == "asantegrifice@gmail.com" || request.auth.token.email == "oseikwameemmanuel33@gmail.com"));
    }

    function isEditor() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor';
    }

    function isStaff() {
      return isAdmin() || isEditor();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidService(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000 &&
             data.iconName is string && data.color is string;
    }

    function isValidGalleryItem(data) {
      return data.type in ['image', 'video'] &&
             data.url is string && data.url.size() > 0 &&
             data.title is string && data.title.size() > 0 &&
             data.category in ['events', 'entertainment', 'consulting'];
    }

    function isValidUser(data) {
      return data.email is string && data.role in ['admin', 'editor', 'guest'];
    }

    function isValidBooking(data) {
      return data.userName is string && data.userName.size() > 0 && data.userName.size() < 100 &&
             data.userEmail is string && data.userEmail.size() > 0 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.time is string && data.time.size() > 0 &&
             data.status in ['pending', 'confirmed', 'cancelled'];
    }

    function isValidTeamMember(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role is string && data.role.size() > 0 && data.role.size() < 100 &&
             data.experience is string && data.experience.size() > 0 &&
             data.bio is string && data.bio.size() > 0 &&
             (!data.keys().hasAny(['email']) || (data.email is string && data.email.size() < 120));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow list: if isAuthenticated() && (isStaff() || resource.data.email == request.auth.token.email);
      allow create: if (isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'guest') || isAdmin();
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && isValidUser(request.resource.data));
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isStaff() && isValidService(request.resource.data);
    }

    match /gallery/{itemId} {
      allow read: if true;
      allow create: if isStaff() && isValidGalleryItem(request.resource.data);
      allow update: if isStaff() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likesCount', 'comments'])
      );
      allow delete: if isStaff();
    }

    match /portfolio/{itemId} {
      allow read: if true;
      allow create: if isStaff();
      allow update: if isStaff() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likesCount', 'comments'])
      );
      allow delete: if isStaff();
    }

    match /chat/{messageId} {
      // Allow read if staff OR if it belongs to the user
      // Note: For guests, we rely on the chatId being a non-guessable random string
      allow read: if isStaff() || 
                    (isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.chatId == request.auth.uid)) ||
                    (resource.data.chatId != null);
      
      allow create: if (isAuthenticated() || request.resource.data.chatId != null) && 
                      request.resource.data.text is string && 
                      request.resource.data.text.size() > 0 && 
                      request.resource.data.text.size() < 1000;
      allow update: if isStaff(); // Admins might bridge or moderate
    }

    match /chat_status/{chatId} {
      // Allow read/write for staff or anyone with the chatId
      allow read: if true;
      allow write: if true; 
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow get, list: if true;
      allow create: if isValidBooking(request.resource.data);
      allow update, delete: if isStaff();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || (isStaff() && resource.data.userId == 'admin'));
      allow create: if isAuthenticated() || isStaff() || request.resource.data.userId == 'admin'; 
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])) ||
        (isStaff() && resource.data.userId == 'admin' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']))
      );
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || (isStaff() && resource.data.userId == 'admin'));
    }
    
    match /tasks/{taskId} {
      allow read, write: if isStaff();
    }
    
    match /team_members/{memberId} {
      allow read: if true;
      allow write: if isStaff() && isValidTeamMember(request.resource.data);
    }

    match /messages/{messageId} {
      allow read: if isStaff();
      allow create: if request.resource.data.senderName is string && request.resource.data.senderName.size() > 0 &&
                    request.resource.data.senderEmail is string && request.resource.data.senderEmail.size() > 0 &&
                    request.resource.data.message is string && request.resource.data.message.size() > 0;
      allow update, delete: if isStaff();
    }
    
    match /test/connection {
      allow read: if true;
    }

    match /site_visits/{dateStr} {
      allow read: if true;
      allow create, update: if true;
    }
  }
}
