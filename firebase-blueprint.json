{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A consulting or entertainment service offered by Grefas.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the service" },
        "description": { "type": "string", "description": "Detailed description of the service" },
        "iconName": { "type": "string", "description": "Lucide icon name" },
        "color": { "type": "string", "description": "Tailwind color classes for the icon background" },
        "order": { "type": "number", "description": "Display order" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "iconName", "color"]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "An image or video in the gallery.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["image", "video"], "description": "Type of media" },
        "url": { "type": "string", "description": "URL of the image or video embed" },
        "thumbnail": { "type": "string", "description": "Thumbnail URL for videos" },
        "title": { "type": "string", "description": "Title of the item" },
        "category": { "type": "string", "enum": ["events", "entertainment", "consulting"], "description": "Category for filtering" },
        "likes": { "type": "array", "items": { "type": "string" }, "description": "Array of user UIDs who liked" },
        "likesCount": { "type": "number", "description": "Total number of likes" },
        "comments": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "url", "title", "category"]
    },
    "PortfolioItem": {
      "title": "Portfolio Item",
      "description": "A project or work sample.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "imageUrl", "category"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the live chat.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "text", "timestamp"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global website settings like contact info.",
      "type": "object",
      "properties": {
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "aboutContent": { "type": "string" },
        "aboutImageUrl": { "type": "string" },
        "dailyQuote": { "type": "string", "description": "Inspiring daily quote managed by admin" },
        "facebook": { "type": "string" },
        "youtube": { "type": "string" },
        "tiktok": { "type": "string" },
        "logoUrl": { "type": "string", "description": "URL of the website logo" }
      }
    },
    "User": {
      "title": "User",
      "description": "Admin user profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "editor"] }
      },
      "required": ["email", "role"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A service booking request.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "userPhone": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceTitle": { "type": "string" },
        "teamMemberId": { "type": "string", "description": "The specific team member chosen" },
        "teamMemberName": { "type": "string", "description": "The name of the chosen team member" },
        "date": { "type": "string", "description": "ISO date string (YYYY-MM-DD)" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName", "userEmail", "date", "status", "createdAt"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "A consultant or team member of Grefas.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The full name of the team member" },
        "role": { "type": "string", "description": "Title, e.g., Senior Business Consultant" },
        "experience": { "type": "string", "description": "Description of professional experience" },
        "bio": { "type": "string", "description": "Biography or detailed description" },
        "imageUrl": { "type": "string", "description": "URL of the profile image" },
        "email": { "type": "string", "format": "email", "description": "The email address where direct messages are routed" },
        "rating": { "type": "number", "description": "Rating out of 5 stars (optional)" },
        "skills": { "type": "array", "items": { "type": "string" }, "description": "Key skills or expertise areas" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "experience", "bio"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Inquiry or booking message sent to a professional.",
      "type": "object",
      "properties": {
        "senderName": { "type": "string" },
        "senderEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "recipientId": { "type": "string" },
        "recipientName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderName", "senderEmail", "message"]
    },
    "SiteVisit": {
      "title": "Site Visit",
      "description": "A daily counter tracking unique visitor sessions on the Grefas site.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "description": "The date of the session YYYY-MM-DD" },
        "count": { "type": "number", "description": "Number of unique sessions on this day" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last increment timestamp" }
      },
      "required": ["date", "count"]
    }
  },
  "firestore": {
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of services"
    },
    "/gallery/{itemId}": {
      "schema": "GalleryItem",
      "description": "Collection of gallery items"
    },
    "/portfolio/{itemId}": {
      "schema": "PortfolioItem",
      "description": "Collection of portfolio items"
    },
    "/chat/{messageId}": {
      "schema": "ChatMessage",
      "description": "Collection of chat messages"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global settings document"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Admin user profiles"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of bookings. bookingId is typically the date string YYYY-MM-DD to enforce uniqueness."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of user notifications"
    },
    "/team_members/{memberId}": {
      "schema": "TeamMember",
      "description": "Collection of team members (consultants, entertainment hosts, etc.)"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of inquiry and booking messages sent directly to specific specialists."
    },
    "/site_visits/{dateStr}": {
      "schema": "SiteVisit",
      "description": "Daily counts of unique website visitors"
    }
  }
}
