{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A consulting or entertainment service offered by Grefas.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the service" },
        "description": { "type": "string", "description": "Detailed description of the service" },
        "iconName": { "type": "string", "description": "Lucide icon name" },
        "color": { "type": "string", "description": "Tailwind color classes for the icon background" },
        "category": { "type": "string", "description": "The category of this service, such as Consulting or Entertainment" },
        "order": { "type": "number", "description": "Display order" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "iconName", "color"]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "An image or video in the gallery.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["image", "video"], "description": "Type of media" },
        "url": { "type": "string", "description": "URL of the image or video embed" },
        "thumbnail": { "type": "string", "description": "Thumbnail URL for videos" },
        "title": { "type": "string", "description": "Title of the item" },
        "category": { "type": "string", "enum": ["events", "entertainment", "consulting"], "description": "Category for filtering" },
        "likes": { "type": "array", "items": { "type": "string" }, "description": "Array of user UIDs who liked" },
        "likesCount": { "type": "number", "description": "Total number of likes" },
        "comments": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "url", "title", "category"]
    },
    "PortfolioItem": {
      "title": "Portfolio Item",
      "description": "A project or work sample.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "imageUrl", "category"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the live chat.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "text", "timestamp"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global website settings like contact info.",
      "type": "object",
      "properties": {
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "aboutContent": { "type": "string" },
        "aboutImageUrl": { "type": "string" },
        "dailyQuote": { "type": "string", "description": "Inspiring daily quote managed by admin" },
        "facebook": { "type": "string" },
        "youtube": { "type": "string" },
        "tiktok": { "type": "string" },
        "logoUrl": { "type": "string", "description": "URL of the website logo" }
      }
    },
    "User": {
      "title": "User",
      "description": "User account profile and preferences.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "fullName": { "type": "string", "description": "The user's display or full name" },
        "phone": { "type": "string", "description": "The user's telephone number" },
        "role": { "type": "string", "description": "The user's access role (admin, editor, guest)" },
        "emailNotificationsEnabled": { "type": "boolean", "description": "Whether the user wants to receive updates when their application status changes" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "An article or blog post.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "content": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "readTime": { "type": "string" },
        "image": { "type": "string" },
        "author": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "summary", "content", "category", "date", "image", "author"]
    },
    "NewsletterSubscriber": {
      "title": "Newsletter Subscriber",
      "description": "A subscribed email for the mailing list.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      },
      "required": ["email", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A service booking request.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "userPhone": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceTitle": { "type": "string" },
        "teamMemberId": { "type": "string", "description": "The specific team member chosen" },
        "teamMemberName": { "type": "string", "description": "The name of the chosen team member" },
        "date": { "type": "string", "description": "ISO date string (YYYY-MM-DD)" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName", "userEmail", "date", "status", "createdAt"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "A consultant or team member of Grefas.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The full name of the team member" },
        "role": { "type": "string", "description": "Title, e.g., Senior Business Consultant" },
        "experience": { "type": "string", "description": "Description of professional experience" },
        "bio": { "type": "string", "description": "Biography or detailed description" },
        "imageUrl": { "type": "string", "description": "URL of the profile image" },
        "email": { "type": "string", "format": "email", "description": "The email address where direct messages are routed" },
        "rating": { "type": "number", "description": "Rating out of 5 stars (optional)" },
        "skills": { "type": "array", "items": { "type": "string" }, "description": "Key skills or expertise areas" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "experience", "bio"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Inquiry or booking message sent to a professional.",
      "type": "object",
      "properties": {
        "senderName": { "type": "string" },
        "senderEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "recipientId": { "type": "string" },
        "recipientName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderName", "senderEmail", "message"]
    },
    "SiteVisit": {
      "title": "Site Visit",
      "description": "A daily counter tracking unique visitor sessions on the Grefas site.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "description": "The date of the session YYYY-MM-DD" },
        "count": { "type": "number", "description": "Number of unique sessions on this day" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last increment timestamp" }
      },
      "required": ["date", "count"]
    },
    "ServiceIntake": {
      "title": "Service Intake",
      "description": "A client service intake registration containing structured demographic, age calculation, contact, and email information.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "dateOfBirth": { "type": "string" },
        "age": { "type": "number" },
        "contact": { "type": "string" },
        "address": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "emailAddress": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "In Review", "Approved", "Rejected"], "description": "Dynamic candidate casting assessment status" },
        "userId": { "type": "string", "description": "Authenticated user identifier" },
        "userEmail": { "type": "string", "description": "Authenticated user email copy" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "dateOfBirth", "age", "contact", "address", "whatsappNumber", "emailAddress"]
    },
    "SmsTemplate": {
      "title": "SMS Template",
      "description": "Customizable SMS templates for bookings, applications, and announcements.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Template key name, e.g. booking_received" },
        "title": { "type": "string", "description": "Human readable title" },
        "content": { "type": "string", "description": "Message content with placeholders" },
        "type": { "type": "string", "description": "Category: booking, casting, announcement" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "title", "content", "type"]
    },
    "OfficialLetter": {
      "title": "Official Letter",
      "description": "An official letter sent to an organisation, individual or institution with letterhead and watermark.",
      "type": "object",
      "properties": {
        "recipientType": { "type": "string", "enum": ["organisation", "individual", "institution"] },
        "recipientName": { "type": "string" },
        "recipientAddress": { "type": "string" },
        "date": { "type": "string" },
        "subject": { "type": "string" },
        "salutation": { "type": "string" },
        "body": { "type": "string" },
        "signatoryName": { "type": "string" },
        "signatoryTitle": { "type": "string" },
        "letterheadType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["recipientType", "recipientName", "recipientAddress", "date", "subject", "salutation", "body", "signatoryName", "signatoryTitle", "letterheadType", "createdAt"]
    },
    "NewsletterCampaign": {
      "title": "Newsletter Campaign",
      "description": "A sent newsletter campaign or email update broadcast to multiple clients.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "preheader": { "type": "string" },
        "body": { "type": "string" },
        "templateType": { "type": "string" },
        "recipientGroup": { "type": "string" },
        "recipientCount": { "type": "number" },
        "logoStyle": { "type": "string" },
        "themeAccent": { "type": "string" },
        "ctaEnabled": { "type": "boolean" },
        "ctaText": { "type": "string" },
        "ctaUrl": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "subject", "body", "recipientGroup", "recipientCount", "sentAt"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "A client testimonial or feedback",
      "type": "object",
      "properties": {
        "authorName": { "type": "string" },
        "authorRole": { "type": "string" },
        "rating": { "type": "number" },
        "text": { "type": "string" },
        "approved": { "type": "boolean" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorName", "text", "approved"]
    },
    "VisitorNotification": {
      "title": "VisitorNotification",
      "description": "An announcement or alert shown to visitors on the home page",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "isActive": { "type": "boolean" },
        "type": { "type": "string" },
        "buttonText": { "type": "string" },
        "buttonUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "isActive"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Records client engagement including login history and status changes.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "description", "createdAt"]
    },
    "BookingPass": {
      "title": "Booking Pass",
      "description": "A booking pass validation ticket printed/generated for verified service attendance.",
      "type": "object",
      "properties": {
        "bookingId": { "type": "string" },
        "orderNumber": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "serviceTitle": { "type": "string" },
        "generatedByEmail": { "type": "string" },
        "generatedByName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["bookingId", "orderNumber", "userName", "userEmail", "timestamp"]
    }
  },
  "firestore": {
    "/booking_passes/{passId}": {
      "schema": "BookingPass",
      "description": "Collection of printed booking passes for consultation/entertainment verification"
    },
    "/visitor_notifications/{notificationId}": {
      "schema": "VisitorNotification",
      "description": "Collection of visitor popup notifications managed by admin"
    },
    "/testimonials/{testimonialId}": {
      "schema": "Testimonial",
      "description": "Collection of client testimonials"
    },
    "/newsletter_campaigns/{campaignId}": {
      "schema": "NewsletterCampaign",
      "description": "Collection of sent newsletter and email broadcast updates"
    },
    "/letters/{letterId}": {
      "schema": "OfficialLetter",
      "description": "Collection of sent official letters"
    },
    "/sms_templates/{templateId}": {
      "schema": "SmsTemplate",
      "description": "Collection of saved SMS templates"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of services"
    },
    "/gallery/{itemId}": {
      "schema": "GalleryItem",
      "description": "Collection of gallery items"
    },
    "/portfolio/{itemId}": {
      "schema": "PortfolioItem",
      "description": "Collection of portfolio items"
    },
    "/chat/{messageId}": {
      "schema": "ChatMessage",
      "description": "Collection of chat messages"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global settings document"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Admin user profiles"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of bookings. bookingId is typically the date string YYYY-MM-DD to enforce uniqueness."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of user notifications"
    },
    "/team_members/{memberId}": {
      "schema": "TeamMember",
      "description": "Collection of team members (consultants, entertainment hosts, etc.)"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of inquiry and booking messages sent directly to specific specialists."
    },
    "/site_visits/{dateStr}": {
      "schema": "SiteVisit",
      "description": "Daily counts of unique website visitors"
    },
    "/blogs/{blogId}": {
      "schema": "BlogPost",
      "description": "Collection of blog posts"
    },
    "/newsletter/{subscriberId}": {
      "schema": "NewsletterSubscriber",
      "description": "Collection of newsletter subscriptions"
    },
    "/service_intakes/{intakeId}": {
      "schema": "ServiceIntake",
      "description": "Collection of service client intake registrations"
    },
    "/activity_logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Log of client activities, logins, and status updates"
    }
  }
}
